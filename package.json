{
  "name": "sontha",
  "version": "1.0.0",
  "description": "Modern messenger with dark theme, email verification, and WebRTC support",
  "main": "main.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "desktop": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.sontha.messenger",
    "productName": "Sontha Messenger",
    "copyright": "Copyright © 2025 Sontha Team",
    "win": {
      "target": "nsis",
      "forceCodeSigning": false
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "keywords": [
    "messenger",
    "electron",
    "socket.io",
    "webrtc"
  ],
  "author": "Sontha Team",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.9",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.16.3",
    "simple-peer": "^9.11.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.7.2",
    "node-fetch": "^3.3.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "electron": "^28.0.0",
    "electron-builder": "^26.0.12"
  }
}
