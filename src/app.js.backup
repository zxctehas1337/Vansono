    '--bg-secondary': '#f5f5f5',
    '--bg-tertiary': '#e5e5e5',
    '--text-primary': '#1a1a1a',
    '--text-secondary': '#666666',
    '--text-tertiary': '#999999',
    '--accent-primary': '#667eea',
    '--accent-secondary': '#764ba2',
    '--border-color': '#e0e0e0',
